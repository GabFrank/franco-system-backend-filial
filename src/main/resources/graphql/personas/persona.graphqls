type Persona {
    id:ID!,
    nombre: String
    apodo: String
    nacimiento: Date
    documento: String
    email: String
    sexo: String
    direccion: String
    ciudad: Ciudad
    telefono: String
    socialMedia: String
    imagenes: String
    creadoEn: Date
    usuario: Usuario
    isFuncionario: Boolean
    isCliente: Boolean
    isProveedor: Boolean
    isUsuario: Boolean
}

type PersonaPage {
    getTotalPages: Int
    getTotalElements: Int
    getNumberOfElements: Int
    isFirst: Boolean
    isLast: Boolean
    hasNext: Boolean
    hasPrevious: Boolean
    getContent: [Persona]
    getPageable: Pageable
}

input PersonaInput {
    id:ID
    nombre: String
    apodo: String
    documento: String
    nacimiento: Date
    sexo: String
    direccion: String
    email: String
    ciudadId: Int
    telefono: String
    socialMedia: String
    imagenes: String
    creadoEn: Date
    usuarioId: Int
}

extend type Query {
    persona(id:ID!):Persona
    personaSearch(texto:String):[Persona]
    personaSearchPage(texto:String, page:Int = 0, size:Int = 10):PersonaPage
    personas(page:Int = 0, size:Int = 10):[Persona]!
    personasPage(page:Int = 0, size:Int = 10):PersonaPage
    countPersona:Int
    personaPorDocumento(texto:String):Persona
}

extend type Mutation {
    savePersona(persona:PersonaInput!):Persona!
    deletePersona(id:ID!):Boolean!
#    updatePersona(id:ID!, persona:PersonaInput!):Persona!
}

