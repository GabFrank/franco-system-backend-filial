type Usuario {
    id:ID!
    persona: Persona
    password: String
    nickname: String
    creadoEn: Date
    usuario: Usuario
    roles: [String]
    activo: Boolean
    inicioSesion: InicioSesion
}

type UsuarioSimilitud {
    usuario: Usuario
    similitud: Float
}

input UsuarioInput {
    id:ID
    personaId: Int
    password: String
    nickname: String
    usuarioId: Int
    creadoEn: Date
    activo: Boolean
}

extend type Query {
    usuario(id:ID!):Usuario
    usuarioPorPersonaId(id:ID!):Usuario
    usuarios(page:Int = 0, size:Int = 10):[Usuario]!
    countUsuario:Int
    usuarioSearch(texto:String):[Usuario]
    verificarUsuario(texto:String): Boolean
    getUsuarioImages(id:ID!, type:String!):[String]
    usuariosActivos:[Usuario]
    usuarioPorEmbedding(embedding: [Float], excludeIds: [Int]): UsuarioSimilitud
}

extend type Mutation {

    saveUsuario(usuario:UsuarioInput!):Usuario!

    deleteUsuario(id:ID!):Boolean!
    
    saveUserImage(id:ID!, type:String!, image:String!):Boolean!
}


